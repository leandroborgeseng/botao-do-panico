PORT=3001
# Obrigatório em produção. Em dev pode usar o valor abaixo.
JWT_SECRET=change-me-in-production
# SQLite (dev). Em produção pode usar PostgreSQL: postgresql://user:pass@host:5432/db
DATABASE_URL=file:./dev.db
BASE_URL=http://localhost:3001
# Em produção: origens permitidas separadas por vírgula (ex.: https://app.exemplo.org,https://admin.exemplo.org)
# CORS_ORIGINS=https://seusite.com

# Opcional: FCM (deixe vazio para modo MOCK)
# FIREBASE_SERVICE_ACCOUNT_PATH=path/to/serviceAccountKey.json
# ou
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
