PORT=3001
BASE_URL=http://localhost:3001

# Obrigatório em produção (Railway). Em dev pode usar o valor abaixo.
JWT_SECRET=change-me-in-production

# PostgreSQL (produção Railway) ou SQLite (dev): file:./dev.db
# Formato Postgres: postgresql://USER:SENHA@HOST:PORTA/DATABASE
DATABASE_URL=file:./dev.db

# Obrigatório em produção: origens permitidas separadas por vírgula
# Ex.: https://seu-app.vercel.app,https://outro-dominio.com
CORS_ORIGINS=

# Opcional: FCM (deixe vazio para modo MOCK)
# FIREBASE_SERVICE_ACCOUNT_PATH=path/to/serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
